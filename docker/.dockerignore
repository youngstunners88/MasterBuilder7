# =============================================================================
# MasterBuilder7 - Docker Build Context Ignore
# Optimizes build by excluding unnecessary files
# =============================================================================

# Git
.git
.gitignore
.gitattributes
.git-credentials

# Python
__pycache__
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
env/
*.egg-info/
dist/
build/
*.egg
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/

# Virtual Environments (any level)
**/.venv/
**/venv/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn
.pnpm

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# Documentation
*.md
!README.md
docs/
*.rst
*.txt
!requirements.txt

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
azure-pipelines.yml

# Docker
Dockerfile*
docker-compose*.yml
.docker/
docker/data/
docker/logs/

# Logs and databases
*.log
logs/
*.sqlite
*.db

# Test files
tests/
test/
*_test.py
test_*.py

# Local development
.env
.env.local
.env.*.local
.env.example
*.local

# Data files (mount as volumes instead)
data/
*.csv
*.json
!mcp_config.json
!package.json
*.parquet
*.h5
*.pkl
*.pickle

# Large model files (download in container)
models/
*.pt
*.pth
*.onnx
*.pb
*.h5
*.safetensors

# Cache directories
.cache/
**/.cache/
*.cache

# Temporary files
tmp/
temp/
*.tmp

# Backup files
*.bak
*.backup
*~

# OS files
Thumbs.db
.DS_Store
.directory

# Rust builds (subatomic-agents)
target/
Cargo.lock
**/*.rs.bk

# Android builds
*.apk
*.aab
android-sdk/
.gradle/

# Video and media files
*.mp4
*.mov
*.avi
*.mkv
*.webm
videos/

# Archives
*.tar
*.gz
*.bz2
*.zip
*.rar
*.7z

# Secrets (ensure no secrets in image)
secrets/
*.pem
*.key
*.crt
id_rsa
id_rsa.pub
.ssh/

# Specific project exclusions
cost-tracking/
dashboard/
sub-agents/
skills/
ELITE-SQUAD-8/
workflows/
n8n-workflows/
