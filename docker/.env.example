# =============================================================================
# MasterBuilder7 - Environment Configuration Example
# Copy this file to .env and fill in your values
# =============================================================================

# =============================================================================
# Application Settings
# =============================================================================
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
VERSION=latest

# =============================================================================
# Security
# =============================================================================
API_KEY=your-secret-api-key-here
SECRET_KEY=your-super-secret-key-change-in-production
JWT_SECRET=your-jwt-secret-key

# =============================================================================
# Database
# =============================================================================
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/masterbuilder7

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=

# =============================================================================
# Celery
# =============================================================================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# =============================================================================
# MCP Server
# =============================================================================
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8080
MCP_HTTP_PORT=8000
UVICORN_WORKERS=4

# =============================================================================
# Monitoring
# =============================================================================
ENABLE_METRICS=true
METRICS_PORT=9090
SENTRY_DSN=

# =============================================================================
# Grafana
# =============================================================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:3000

# =============================================================================
# Flower
# =============================================================================
FLOWER_AUTH=admin:admin
FLOWER_PORT=5555

# =============================================================================
# SMTP (for Grafana alerts)
# =============================================================================
SMTP_HOST=smtp.gmail.com:587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=alerts@masterbuilder7.local

# =============================================================================
# SSL/TLS (Production)
# =============================================================================
SSL_CERT_PATH=/etc/ssl/certs/mb7.crt
SSL_KEY_PATH=/etc/ssl/private/mb7.key

# =============================================================================
# External AI Services (optional)
# =============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# =============================================================================
# n8n Integration (optional)
# =============================================================================
N8N_WEBHOOK_URL=
N8N_API_KEY=
