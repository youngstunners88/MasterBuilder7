# MasterBuilder7 Monitoring Stack - Environment Configuration
# Copy to .env and fill in your values

# ==========================================
# GRAFANA CONFIGURATION
# ==========================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme-strong-password
GRAFANA_ROOT_URL=http://localhost:3000

# ==========================================
# ALERT NOTIFICATIONS - Slack
# ==========================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ==========================================
# ALERT NOTIFICATIONS - PagerDuty
# ==========================================
PAGERDUTY_SERVICE_KEY=your-pagerduty-service-key

# ==========================================
# ALERT NOTIFICATIONS - Email (SMTP)
# ==========================================
SMTP_ENABLED=true
SMTP_HOST=smtp.gmail.com:587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=alerts@masterbuilder7.local
SMTP_FROM_NAME=MasterBuilder7 Alerts

# ==========================================
# ALERT NOTIFICATIONS - Webhook
# ==========================================
WEBHOOK_SECRET_TOKEN=your-secret-webhook-token
ALERTMANAGER_EXTERNAL_URL=http://localhost:9093

# ==========================================
# MONITORING ENDPOINTS
# ==========================================
# Set these if your MasterBuilder7 API runs on different hosts
MB7_API_HOST=api
MB7_API_PORT=8000

# ==========================================
# RETENTION SETTINGS (optional)
# ==========================================
PROMETHEUS_RETENTION_DAYS=30
PROMETHEUS_RETENTION_SIZE_GB=50
LOKI_RETENTION_DAYS=30
TEMPO_RETENTION_DAYS=7
